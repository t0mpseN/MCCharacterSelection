{
	"schemaVersion": 1,
	"id": "nexuscharacters",
	"version": "${version}",
	"name": "Nexus Characters",
	"description": "A Minecraft mod that lets you play with multiple characters in multiple worlds, while keeping each character's individual progress between them. Works both in singleplayer and multiplayer (if the server has this mod installed). ",
	"authors": [
		"t0mpseN"
	],
	"contact": {
		"homepage": "https://ko-fi.com/pedrotompsen",
		"sources": "https://github.com/t0mpseN/NexusCharacters"
	},
	"license": "MIT",
	"icon": "assets/nexuscharacters/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.tompsen.nexuscharacters.NexusCharacters"
		],
		"client": [
			"net.tompsen.nexuscharacters.NexusCharactersClient"
		],
		"fabric-datagen": [
		]
	},
	"mixins": [
		"nexuscharacters.mixins.json",
		{
			"config": "nexuscharacters.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}